# ── Ollama Connection ──
OLLAMA_HOST=http://localhost:11434

# ── Model timeout (minutes of inactivity before auto-unload) ──
MODEL_TIMEOUT_MINUTES=15

# ── How long Ollama keeps model loaded during active chat ──
OLLAMA_KEEP_ALIVE=10m

# ── Optional auth token (leave empty for no auth) ──
AUTH_TOKEN=

# ── Data directory ──
DATA_DIR=./data
